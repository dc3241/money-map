# Copy to `.env` for local builds. Production/hosting must inject these at **build** time (Vite embeds `VITE_*`).

# Firebase web config (Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase App Check — reCAPTCHA v3 *site* key (public). Firebase Console → App Check → Register web app.
# Required so HTTPS callables (Plaid sync, link token, disconnect, Money Coach) pass enforceAppCheck on the backend.
VITE_RECAPTCHA_V3_SITE_KEY=
