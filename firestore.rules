rules_version = '2';
// Security notes:
// - Plaid tokens live under users/{uid}/plaidData — client read-only; only Cloud Functions write.
// - Transaction category overrides/rules are client-managed under users/{uid}/transactionCategory* —
//   used for budget categorization (must be explicit subcollection rules; parent user doc rule does not apply).
// - Support: admin access is granted by Firebase custom claim `admin: true`.
//   During migration, adminUsers/{uid} is still accepted as a fallback.

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminUser() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
      );
    }

    // Admin allowlist (UIDs only). Create via Console: adminUsers/{uid} = { "active": true }
    match /adminUsers/{adminId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /plaidData/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /accounts/{accountId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /transactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /recurringReview/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.keys().hasOnly([
                          "transactionId",
                          "decision",
                          "kind",
                          "cadence",
                          "category",
                          "incomeType",
                          "source",
                          "updatedAt"
                        ])
                     && request.resource.data.transactionId is string
                     && request.resource.data.transactionId.size() > 0
                     && request.resource.data.transactionId == docId
                     && request.resource.data.decision in ["recurring", "not_recurring"]
                     && (
                          !("kind" in request.resource.data)
                          || request.resource.data.kind == null
                          || request.resource.data.kind in ["income", "expense"]
                        )
                     && (
                          !("cadence" in request.resource.data)
                          || request.resource.data.cadence == null
                          || request.resource.data.cadence is string
                        )
                     && (
                          !("category" in request.resource.data)
                          || request.resource.data.category == null
                          || request.resource.data.category is string
                        )
                     && (
                          !("incomeType" in request.resource.data)
                          || request.resource.data.incomeType == null
                          || request.resource.data.incomeType is string
                        )
                     && (
                          !("source" in request.resource.data)
                          || request.resource.data.source == null
                          || request.resource.data.source is string
                        )
                     && (
                          !("updatedAt" in request.resource.data)
                          || request.resource.data.updatedAt == null
                          || request.resource.data.updatedAt is timestamp
                        );
      }

      // Per-transaction category overrides (document ID = Plaid transaction_id)
      match /transactionCategoryOverrides/{overrideId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
               "transactionId",
               "categoryId",
               "source",
               "updatedAt"
             ])
          && request.resource.data.transactionId is string
          && request.resource.data.transactionId == overrideId
          && request.resource.data.categoryId is string
          && request.resource.data.categoryId.size() > 0
          && request.resource.data.source == 'user'
          && request.resource.data.updatedAt is timestamp;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Merchant / pattern rules for default Plaid transaction → app category mapping
      // Money Coach chat persistence (primary thread + messages)
      match /assistantThreads/{threadId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId
          && threadId.size() > 0 && threadId.size() <= 64
          && request.resource.data.keys().hasOnly(["updatedAt"])
          && request.resource.data.updatedAt is timestamp;
        allow delete: if request.auth != null && request.auth.uid == userId;

        match /messages/{messageId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow create: if request.auth != null && request.auth.uid == userId
            && request.resource.data.keys().hasOnly(["role", "content", "createdAt"])
            && request.resource.data.role in ["user", "assistant"]
            && request.resource.data.content is string
            && request.resource.data.content.size() > 0
            && request.resource.data.content.size() <= 12000
            && request.resource.data.createdAt is timestamp;
          allow delete: if request.auth != null && request.auth.uid == userId;
          allow update: if false;
        }
      }

      match /transactionCategoryRules/{ruleId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.categoryId is string
          && request.resource.data.categoryId.size() > 0
          && request.resource.data.priority is number
          && request.resource.data.matcher is map
          && request.resource.data.matcher.keys().hasOnly([
               "merchantContains",
               "accountId",
               "amountMin",
               "amountMax",
               "direction"
             ])
          && (!("merchantContains" in request.resource.data.matcher)
              || request.resource.data.matcher.merchantContains == null
              || request.resource.data.matcher.merchantContains is string)
          && (!("accountId" in request.resource.data.matcher)
              || request.resource.data.matcher.accountId == null
              || request.resource.data.matcher.accountId is string)
          && (!("amountMin" in request.resource.data.matcher)
              || request.resource.data.matcher.amountMin == null
              || request.resource.data.matcher.amountMin is number)
          && (!("amountMax" in request.resource.data.matcher)
              || request.resource.data.matcher.amountMax == null
              || request.resource.data.matcher.amountMax is number)
          && request.resource.data.matcher.direction in ["expense", "income", "any"]
          && request.resource.data.updatedAt is timestamp
          && (!("active" in request.resource.data)
              || request.resource.data.active is bool)
          && (!("createdAt" in request.resource.data)
              || request.resource.data.createdAt == null
              || request.resource.data.createdAt is timestamp)
          && (!("id" in request.resource.data)
              || request.resource.data.id == null
              || request.resource.data.id is string);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /supportTickets/{ticketId} {
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasOnly([
                      "userId",
                      "userEmail",
                      "userName",
                      "subject",
                      "message",
                      "status",
                      "createdAt",
                      "updatedAt",
                      "responses"
                    ])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userEmail == request.auth.token.email
                    && (!("userName" in request.resource.data)
                        || request.resource.data.userName == null
                        || (request.resource.data.userName is string
                            && request.resource.data.userName.size() <= 120))
                    && request.resource.data.subject is string
                    && request.resource.data.subject.size() > 0
                    && request.resource.data.subject.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.status in ["open", "in-progress", "resolved", "closed"]
                    && request.resource.data.createdAt is string
                    && request.resource.data.updatedAt is string
                    && request.resource.data.responses is list
                    && request.resource.data.responses.size() == 0;

      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdminUser()
      );

      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.userEmail == resource.data.userEmail
                    && request.resource.data.keys().hasOnly([
                      "userId",
                      "userEmail",
                      "userName",
                      "subject",
                      "message",
                      "status",
                      "createdAt",
                      "updatedAt",
                      "responses"
                    ])
                    && (!("userName" in request.resource.data)
                        || request.resource.data.userName == null
                        || (request.resource.data.userName is string
                            && request.resource.data.userName.size() <= 120))
                    && request.resource.data.subject is string
                    && request.resource.data.subject.size() > 0
                    && request.resource.data.subject.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.status in ["open", "in-progress", "resolved", "closed"]
                    && request.resource.data.createdAt is string
                    && request.resource.data.updatedAt is string
                    && request.resource.data.responses is list;

      allow update: if isAdminUser()
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.userEmail == resource.data.userEmail
                    && request.resource.data.keys().hasOnly([
                      "userId",
                      "userEmail",
                      "userName",
                      "subject",
                      "message",
                      "status",
                      "createdAt",
                      "updatedAt",
                      "responses"
                    ])
                    && (!("userName" in request.resource.data)
                        || request.resource.data.userName == null
                        || (request.resource.data.userName is string
                            && request.resource.data.userName.size() <= 120))
                    && request.resource.data.subject is string
                    && request.resource.data.subject.size() > 0
                    && request.resource.data.subject.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.status in ["open", "in-progress", "resolved", "closed"]
                    && request.resource.data.createdAt is string
                    && request.resource.data.updatedAt is string
                    && request.resource.data.responses is list;
    }
  }
}
